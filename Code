<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Web Dev Crash Course App</title>
<style>
  /* --- GLOBAL STYLES & VARIABLES --- */
  :root {
    --bg: #0f172a; --surface: #1e293b; --primary: #3b82f6; 
    --success: #10b981; --danger: #ef4444; --text: #f8fafc; --muted: #94a3b8;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: 'Segoe UI', system-ui, sans-serif; background: var(--bg); color: var(--text); display: flex; height: 100vh; overflow: hidden; }

  /* --- SIDEBAR NAV --- */
  aside { width: 260px; background: var(--surface); padding: 2rem 1rem; display: flex; flex-direction: column; border-right: 1px solid #334155; }
  aside h2 { font-size: 1.2rem; margin-bottom: 2rem; color: var(--primary); text-align: center; }
  .nav-btn { background: transparent; border: none; color: var(--muted); padding: 12px 16px; text-align: left; font-size: 1rem; cursor: pointer; border-radius: 8px; margin-bottom: 8px; transition: 0.2s; }
  .nav-btn:hover { background: #334155; color: var(--text); }
  .nav-btn.active { background: var(--primary); color: white; font-weight: bold; }
  .progress-bar { margin-top: auto; background: #334155; height: 8px; border-radius: 4px; overflow: hidden; }
  .progress-fill { height: 100%; background: var(--success); transition: width 0.5s ease; }
  .progress-text { font-size: 0.8rem; color: var(--muted); margin-top: 8px; text-align: center; }

  /* --- MAIN CONTENT --- */
  main { flex: 1; padding: 3rem; overflow-y: auto; position: relative; }
  h1 { margin-bottom: 1rem; font-size: 2rem; }
  p { color: var(--muted); line-height: 1.6; margin-bottom: 1.5rem; }
  .card { background: var(--surface); padding: 2rem; border-radius: 12px; margin-bottom: 2rem; border: 1px solid #334155; }
  
  /* --- INFOGRAPHICS (CSS DRAWN) --- */
  .dom-tree { font-family: monospace; background: #000; padding: 20px; border-radius: 8px; color: #10b981; line-height: 1.5; }
  .dom-tree span { color: #3b82f6; }
  .flow-diagram { display: flex; align-items: center; gap: 20px; justify-content: center; margin: 30px 0; flex-wrap: wrap; }
  .flow-box { background: var(--primary); padding: 15px 25px; border-radius: 8px; font-weight: bold; text-align: center; }
  .flow-arrow { font-size: 2rem; color: var(--muted); }

  /* --- FLASHCARDS --- */
  .flashcard-container { perspective: 1000px; width: 100%; max-width: 400px; height: 250px; margin: 2rem auto; cursor: pointer; }
  .flashcard-inner { position: relative; width: 100%; height: 100%; transition: transform 0.6s; transform-style: preserve-3d; }
  .flashcard-container.flipped .flashcard-inner { transform: rotateY(180deg); }
  .flashcard-front, .flashcard-back { position: absolute; width: 100%; height: 100%; backface-visibility: hidden; display: flex; flex-direction: column; align-items: center; justify-content: center; border-radius: 12px; padding: 20px; text-align: center; }
  .flashcard-front { background: #334155; border: 2px dashed var(--primary); }
  .flashcard-back { background: var(--primary); transform: rotateY(180deg); color: white; }
  .card-controls { display: flex; gap: 10px; justify-content: center; margin-top: 10px; }
  .btn { padding: 10px 20px; border: none; border-radius: 6px; cursor: pointer; font-weight: bold; transition: 0.2s; }
  .btn-primary { background: var(--primary); color: white; }
  .btn-primary:hover { background: #2563eb; }

  /* --- QUIZZES --- */
  .quiz-option { display: block; width: 100%; text-align: left; background: #334155; border: 1px solid transparent; color: var(--text); padding: 15px; margin-bottom: 10px; border-radius: 8px; cursor: pointer; transition: 0.2s; }
  .quiz-option:hover { border-color: var(--primary); }
  .quiz-option.correct { background: rgba(16, 185, 129, 0.2); border-color: var(--success); color: var(--success); }
  .quiz-option.incorrect { background: rgba(239, 68, 68, 0.2); border-color: var(--danger); color: var(--danger); }
  .feedback { margin-top: 15px; padding: 15px; border-radius: 8px; display: none; }

  /* --- SANDBOX --- */
  .sandbox { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
  .sandbox-input { width: 100%; height: 100px; background: #000; color: #10b981; border: 1px solid #334155; padding: 15px; font-family: monospace; border-radius: 8px; resize: none; }
  .sandbox-preview { background: white; border-radius: 8px; display: flex; align-items: center; justify-content: center; color: black; font-weight: bold; transition: 0.3s; min-height: 100px;}
  input[type="color"] { width: 100%; height: 50px; border: none; cursor: pointer; background: none; }

  /* --- FINAL PROJECT --- */
  .project-container { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; height: 60vh; }
  .code-editor { background: #111; color: #f8fafc; padding: 15px; font-family: monospace; font-size: 0.85rem; border-radius: 8px; overflow: auto; white-space: pre; border: 1px solid #334155;}
  .live-app { background: white; color: black; border-radius: 8px; padding: 20px; overflow-y: auto; }
  .live-app input { padding: 8px; width: 70%; margin-right: 5px; }
  .live-app button { padding: 8px 12px; background: var(--primary); color: white; border: none; cursor: pointer; }
  .live-app ul { list-style: none; padding: 0; margin-top: 15px; }
  .live-app li { background: #f1f5f9; padding: 10px; margin-bottom: 5px; display: flex; justify-content: space-between; border-radius: 4px;}
  .live-app .done { text-decoration: line-through; opacity: 0.5; }
</style>
</head>
<body>

<!-- SIDEBAR -->
<aside>
  <h2>🚀 WebDev Crash Course</h2>
  <nav id="nav">
    <button class="nav-btn active" data-day="1">Day 1: HTML Structure</button>
    <button class="nav-btn" data-day="2">Day 2: CSS Flashcards</button>
    <button class="nav-btn" data-day="3">Day 3: JS Quiz</button>
    <button class="nav-btn" data-day="4">Day 4: Live Sandbox</button>
    <button class="nav-btn" data-day="5">Day 5: State & Data</button>
    <button class="nav-btn" data-day="6">Day 6: CSS-in-JS</button>
    <button class="nav-btn" data-day="7">Day 7: Final Project</button>
  </nav>
  <div>
    <div class="progress-bar"><div class="progress-fill" id="progressFill" style="width: 14%"></div></div>
    <div class="progress-text" id="progressText">Day 1 of 7</div>
  </div>
</aside>

<!-- MAIN CONTENT AREA -->
<main id="app">
  <!-- Content injected by JavaScript -->
</main>

<script>
// ==========================================
// APP STATE & DATA
// ==========================================
const state = { currentDay: 1, flashcardIndex: 0, quizAnswered: false };

const flashcards = [
  { q: "display: flex;", a: "Makes children align in a row. Use justify-content for spacing." },
  { q: "margin: 0 auto;", a: "Centers a block element horizontally within its container." },
  { q: "position: absolute;", a: "Removes element from normal flow, positions relative to nearest positioned ancestor." },
  { q: "box-sizing: border-box;", a: "Includes padding and border in the element's total width and height." }
];

const quizData = [
  { q: "Which function selects an element by ID?", options: ["querySelectorAll()", "getElementById()", "querySelector()", "selectElement()"], correct: 1, explanation: "getElementById() is the fastest and most direct way to select a single element by its unique ID." },
  { q: "What does `const` mean in JavaScript?", options: ["Variable can be reassigned", "Variable cannot be reassigned", "It creates a function", "It defines CSS"], correct: 1, explanation: "`const` declares a block-scoped variable whose value cannot be reassigned after initialization." }
];

// ==========================================
// RENDERING ENGINE
// ==========================================
const app = document.getElementById('app');

function navigate(day) {
  state.currentDay = day;
  state.quizAnswered = false;
  state.flashcardIndex = 0;
  
  // Update Nav UI
  document.querySelectorAll('.nav-btn').forEach(btn => btn.classList.remove('active'));
  document.querySelector(`[data-day="${day}"]`).classList.add('active');
  document.getElementById('progressFill').style.width = `${(day / 7) * 100}%`;
  document.getElementById('progressText').textContent = `Day ${day} of 7`;

  // Render Content
  const renderers = { 1: renderDay1, 2: renderDay2, 3: renderDay3, 4: renderDay4, 5: renderDay5, 6: renderDay6, 7: renderDay7 };
  renderers[day]();
}

// --- DAY 1: HTML INFOGRAPHIC ---
function renderDay1() {
  app.innerHTML = `
    <h1>Day 1: HTML (The Skeleton)</h1>
    <p>HTML provides the structure of a web page. Think of it as the bones of a body.</p>
    <div class="card">
      <h3 style="margin-bottom:15px;">📊 The DOM Tree Infographic</h3>
      <div class="dom-tree">
        <span>&lt;!DOCTYPE html&gt;</span><br>
        <span>&lt;html&gt;</span><br>
        &nbsp;&nbsp;├── <span>&lt;head&gt;</span> (Metadata, Title, Links)<br>
        &nbsp;&nbsp;└── <span>&lt;body&gt;</span> (Visible Content)<br>
        &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;├── <span>&lt;header&gt;</span><br>
        &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;├── <span>&lt;main&gt;</span><br>
        &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;│&nbsp;&nbsp;&nbsp;└── <span>&lt;section&gt;</span><br>
        &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;└── <span>&lt;footer&gt;</span><br>
      </div>
    </div>
    <div class="card">
      <h3>🧠 Reactive Task</h3>
      <p>Open your browser console (F12) and type: <code>document.body.style.background = 'red'</code>. You just manipulated the DOM!</p>
    </div>
  `;
}

// --- DAY 2: CSS FLASHCARDS ---
function renderDay2() {
  renderFlashcardUI("CSS Properties", flashcards);
}

function renderFlashcardUI(title, data) {
  const card = data[state.flashcardIndex];
  app.innerHTML = `
    <h1>Day ${state.currentDay}: ${title}</h1>
    <p>Click the card to flip it. Memorize the concepts, then click Next.</p>
    <div class="flashcard-container" id="flashcard">
      <div class="flashcard-inner">
        <div class="flashcard-front"><h2>${card.q}</h2></div>
        <div class="flashcard-back"><p>${card.a}</p></div>
      </div>
    </div>
    <div class="card-controls">
      <button class="btn btn-primary" id="prevBtn" ${state.flashcardIndex === 0 ? 'disabled' : ''}>Previous</button>
      <button class="btn btn-primary" id="nextBtn">${state.flashcardIndex === data.length - 1 ? 'Finish' : 'Next'}</button>
    </div>
  `;
  document.getElementById('flashcard').onclick = () => document.getElementById('flashcard').classList.toggle('flipped');
  document.getElementById('prevBtn').onclick = () => { if(state.flashcardIndex > 0) { state.flashcardIndex--; renderFlashcardUI(title, data); } };
  document.getElementById('nextBtn').onclick = () => { 
    if(state.flashcardIndex < data.length - 1) { state.flashcardIndex++; renderFlashcardUI(title, data); } 
    else navigate(state.currentDay + 1);
  };
}

// --- DAY 3: JS REACTIVE QUIZ ---
function renderDay3() {
  const q = quizData[0];
  app.innerHTML = `
    <h1>Day 3: JavaScript Basics</h1>
    <p>Test your knowledge. Select the correct answer to get instant reactive feedback.</p>
    <div class="card">
      <h3 style="margin-bottom:20px;">${q.q}</h3>
      <div id="options">
        ${q.options.map((opt, i) => `<button class="quiz-option" data-index="${i}">${opt}</button>`).join('')}
      </div>
      <div class="feedback" id="feedback"></div>
    </div>
  `;

  document.querySelectorAll('.quiz-option').forEach(btn => {
    btn.onclick = () => {
      if(state.quizAnswered) return;
      state.quizAnswered = true;
      const idx = parseInt(btn.dataset.index);
      const feedback = document.getElementById('feedback');
      
      if(idx === q.correct) {
        btn.classList.add('correct');
        feedback.style.display = 'block';
        feedback.style.background = 'rgba(16, 185, 129, 0.2)';
        feedback.style.color = '#10b981';
        feedback.innerHTML = `✅ Correct! ${q.explanation}<br><br><button class="btn btn-primary" onclick="navigate(4)">Next Day →</button>`;
      } else {
        btn.classList.add('incorrect');
        document.querySelectorAll('.quiz-option')[q.correct].classList.add('correct');
        feedback.style.display = 'block';
        feedback.style.background = 'rgba(239, 68, 68, 0.2)';
        feedback.style.color = '#ef4444';
        feedback.innerHTML = `❌ Incorrect. ${q.explanation}<br><br><button class="btn btn-primary" onclick="navigate(4)">Next Day →</button>`;
      }
    };
  });
}

// --- DAY 4: LIVE SANDBOX ---
function renderDay4() {
  app.innerHTML = `
    <h1>Day 4: Events & Interactivity</h1>
    <p>JavaScript reacts to user input. Pick a color below and watch the DOM update instantly.</p>
    <div class="card">
      <div class="sandbox">
        <div>
          <label style="display:block; margin-bottom:10px; font-weight:bold;">Input Event Listener:</label>
          <input type="color" id="colorPicker" value="#3b82f6">
          <div class="sandbox-input" contenteditable="true" id="codeDisplay">
document.getElementById('picker')
  .addEventListener('input', (e) => {
    preview.style.background = e.target.value;
  });</div>
        </div>
        <div>
          <label style="display:block; margin-bottom:10px; font-weight:bold;">Live DOM Result:</label>
          <div class="sandbox-preview" id="preview" style="background: #3b82f6; flex-direction: column;">
            <div style="font-size: 2rem;" id="hexText">#3b82f6</div>
          </div>
        </div>
      </div>
    </div>
    <button class="btn btn-primary" onclick="navigate(5)" style="margin-top:20px;">Next Day →</button>
  `;
  
  const picker = document.getElementById('colorPicker');
  picker.addEventListener('input', (e) => {
    document.getElementById('preview').style.background = e.target.value;
    document.getElementById('hexText').textContent = e.target.value;
  });
}

// --- DAY 5: DATA FLOW INFOGRAPHIC ---
function renderDay5() {
  app.innerHTML = `
    <h1>Day 5: State Management</h1>
    <p>In modern apps, data (state) drives the UI. When state changes, the UI re-renders.</p>
    <div class="card">
      <h3 style="margin-bottom:20px;">📈 The Reactive Data Flow</h3>
      <div class="flow-diagram">
        <div class="flow-box" style="background: #ef4444;">User Action<br><small>(Click)</small></div>
        <div class="flow-arrow">→</div>
        <div class="flow-box" style="background: #f59e0b;">Update State<br><small>(Array)</small></div>
        <div class="flow-arrow">→</div>
        <div class="flow-box" style="background: #10b981;">Render()<br><small>(Function)</small></div>
        <div class="flow-arrow">→</div>
        <div class="flow-box">DOM UI<br><small>(Updates)</small></div>
      </div>
    </div>
    <div class="card">
      <h3>The Golden Rule of State</h3>
      <p>Never update the DOM directly. Update your <strong>data array</strong>, then call a <code>render()</code> function that rebuilds the DOM based on that data.</p>
    </div>
    <button class="btn btn-primary" onclick="navigate(6)">Next Day →</button>
  `;
}

// --- DAY 6: CSS-in-JS FLASHCARDS ---
function renderDay6() {
  const data = [
    { q: "el.style.color = 'red'", a: "Inline Style (Left)" },
    { q: "el.classList.add('active')", a: "Class Toggle (Right)" },
    { q: "class={`${done ? 'x' : ''}`}", a: "Dynamic Class (Right)" },
    { q: "el.setAttribute('style', '...')", a: "Inline Style (Left)" }
  ];
  renderFlashcardUI("CSS-in-JS Patterns", data);
}

// --- DAY 7: FINAL PROJECT ---
function renderDay7() {
  app.innerHTML = `
    <h1>Day 7: Final Project 🚀</h1>
    <p>Combine HTML, CSS, and JS. Here is a fully working Task Manager built on the concepts you learned. Interact with it on the right!</p>
    <div class="project-container">
      <div class="code-editor" id="projectCode"></div>
      <div class="live-app" id="liveApp">
        <h2 style="margin-bottom:15px;">📋 Task Manager</h2>
        <div>
          <input type="text" id="taskInput" placeholder="Add a task...">
          <button id="addBtn">Add</button>
        </div>
        <ul id="taskList"></ul>
        <div style="margin-top:15px; font-size:0.9rem; color:#666;">
          Total: <strong id="totalCount">0</strong> | Done: <strong id="doneCount">0</strong>
        </div>
      </div>
    </div>
  `;

  // Show the code in the left panel
  document.getElementById('projectCode').textContent = `// --- STATE ---
let tasks = [];

// --- REACTIVE RENDER ---
function render() {
  const list = document.getElementById('taskList');
  list.innerHTML = tasks.map(task => \`
    <li class="\${task.done ? 'done' : ''}">
      <span>\${task.text}</span>
      <button onclick="toggle(\${task.id})">
        \${task.done ? '↩' : '✓'}
      </button>
    </li>
  \`).join('');
  
  document.getElementById('totalCount').textContent = tasks.length;
  document.getElementById('doneCount').textContent = tasks.filter(t => t.done).length;
}

// --- ACTIONS ---
function addTask() {
  const text = document.getElementById('taskInput').value;
  if(!text) return;
  tasks.push({ id: Date.now(), text, done: false });
  document.getElementById('taskInput').value = '';
  render(); // Re-draw UI
}

function toggle(id) {
  const task = tasks.find(t => t.id === id);
  task.done = !task.done;
  render(); // Re-draw UI
}`;

  // Initialize the Live App functionality
  let tasks = [];
  const taskInput = document.getElementById('taskInput');
  const taskList = document.getElementById('taskList');

  function renderTasks() {
    taskList.innerHTML = tasks.map(task => `
      <li class="${task.done ? 'done' : ''}">
        <span>${task.text}</span>
        <button data-id="${task.id}" class="toggle-btn" style="border:none; background:none; cursor:pointer; font-size:1.2rem;">${task.done ? '↩️' : '✅'}</button>
      </li>
    `).join('');
    document.getElementById('totalCount').textContent = tasks.length;
    document.getElementById('doneCount').textContent = tasks.filter(t => t.done).length;
  }

  document.getElementById('addBtn').onclick = () => {
    if(taskInput.value.trim()) {
      tasks.push({ id: Date.now(), text: taskInput.value, done: false });
      taskInput.value = '';
      renderTasks();
    }
  };

  taskInput.onkeydown = (e) => { if(e.key === 'Enter') document.getElementById('addBtn').click(); };

  taskList.onclick = (e) => {
    if(e.target.classList.contains('toggle-btn')) {
      const id = parseInt(e.target.dataset.id);
      const task = tasks.find(t => t.id === id);
      task.done = !task.done;
      renderTasks();
    }
  };

  renderTasks();
}

// ==========================================
// INITIALIZATION & EVENT LISTENERS
// ==========================================
document.getElementById('nav').addEventListener('click', (e) => {
  if(e.target.classList.contains('nav-btn')) {
    navigate(parseInt(e.target.dataset.day));
  }
});

// Boot up the app
navigate(1);
</script>
</body>
</html>
